{
  "name": "pxdl-bridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bun build --compile src/index.ts --outfile bin/pxdl-bridge",
    "build:sidecar": "bun run build:sidecar:darwin-arm64",
    "build:sidecar:darwin-arm64": "mkdir -p ../desktop/src-tauri/bin && bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile ../desktop/src-tauri/bin/pxdl-bridge-aarch64-apple-darwin",
    "build:sidecar:darwin-x64": "mkdir -p ../desktop/src-tauri/bin && bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile ../desktop/src-tauri/bin/pxdl-bridge-x86_64-apple-darwin",
    "build:sidecar:windows-x64": "mkdir -p ../desktop/src-tauri/bin && bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile ../desktop/src-tauri/bin/pxdl-bridge-x86_64-pc-windows-msvc.exe",
    "install:host:chrome": "mkdir -p \"$HOME/Library/Application Support/Google/Chrome/NativeMessagingHosts\" && cp host/dev.pxdl.bridge.json \"$HOME/Library/Application Support/Google/Chrome/NativeMessagingHosts/\"",
    "install:host:chromium": "mkdir -p \"$HOME/Library/Application Support/Chromium/NativeMessagingHosts\" && cp host/dev.pxdl.bridge.json \"$HOME/Library/Application Support/Chromium/NativeMessagingHosts/\""
  },
  "dependencies": {
    "@pxdl/types": "workspace:*"
  }
}
