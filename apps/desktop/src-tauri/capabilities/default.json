{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the pxdl application",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "log:default",
    "notification:default",
    "core:tray:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/pxdl-daemon",
          "sidecar": true
        },
        {
          "name": "bin/pxdl-bridge",
          "sidecar": true
        }
      ]
    }
  ]
}
