{
  "manifest_version": 3,
  "name": "pxdl Downloader",
  "version": "0.1.0",
  "description": "Route browser downloads through pxdl for accelerated multi-segment downloading",
  "key": "",
  "permissions": ["downloads", "nativeMessaging", "storage", "webRequest"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
