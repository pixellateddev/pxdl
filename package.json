{
  "name": "pxdl-monorepo",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "install:global": "bun run build && sudo mv apps/cli/bin/pxdl apps/daemon/bin/pxdl-daemon /usr/local/bin/"
  },
  "devDependencies": {
    "turbo": "latest",
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest"
  }
}
